{
  "name": "@jittle-lamp/ui",
  "version": "1.3.5",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "bun run build:js && bun run build:types",
    "build:js": "bun build ./src/index.ts --outdir ./dist --target browser --format esm",
    "build:types": "bun x tsc -p tsconfig.build.json"
  },
  "dependencies": {
    "@base-ui-components/react": "^1.0.0-rc.0",
    "lucide-react": "^1.14.0"
  },
  "peerDependencies": {
    "react": "19.2.0"
  },
  "devDependencies": {
    "react": "19.2.0"
  }
}
