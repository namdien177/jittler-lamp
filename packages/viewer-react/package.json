{
  "name": "@jittle-lamp/viewer-react",
  "version": "1.3.4",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "bun run --cwd ../shared build && bun run --cwd ../viewer-core build && bun run build:js && bun run build:types",
    "build:js": "bun build ./src/index.ts --outdir ./dist --target browser --format esm",
    "build:types": "bun x tsc -p tsconfig.build.json"
  },
  "dependencies": {
    "@jittle-lamp/shared": "workspace:*",
    "@jittle-lamp/viewer-core": "workspace:*",
    "clsx": "2.1.1",
    "lucide-react": "^1.14.0"
  },
  "peerDependencies": {
    "react": "19.2.0",
    "react-router": "7.14.2"
  },
  "devDependencies": {
    "react": "19.2.0",
    "react-router": "7.14.2"
  }
}
