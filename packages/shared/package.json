{
  "name": "@jittle-lamp/shared",
  "version": "1.3.1",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "default": "./dist/index.js"
    },
    "./timeline": {
      "types": "./dist/src/timeline.d.ts",
      "default": "./dist/timeline.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "bun run build:js && bun run build:types",
    "build:js": "bun build ./src/index.ts --outdir ./dist --target browser --format esm",
    "build:types": "bun x tsc -p tsconfig.build.json"
  },
  "dependencies": {
    "zod": "3.25.76"
  }
}
