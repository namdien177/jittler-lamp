{
  "name": "@jittle-lamp/viewer-core",
  "version": "1.3.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "bun run build:js && bun run build:types",
    "build:js": "bun build ./src/index.ts --outdir ./dist --target browser --format esm",
    "build:types": "bun x tsc -p tsconfig.build.json"
  },
  "dependencies": {
    "@jittle-lamp/shared": "workspace:*"
  }
}
