{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "noEmit": true,
    "lib": [
      "ES2023",
      "DOM"
    ],
    "types": [
      "bun-types",
      "node",
      "chrome"
    ],
    "jsx": "react-jsx"
  },
  "include": [
    "apps/**/*.ts",
    "apps/**/*.tsx",
    "packages/**/*.ts",
    "packages/**/*.tsx",
    "scripts/**/*.ts",
    "tests/**/*.ts",
    "tests/**/*.tsx"
  ],
  "exclude": [
    "apps/**/dist/**",
    "packages/**/dist/**",
    "release-artifacts/**"
  ]
}
