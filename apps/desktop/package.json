{
  "name": "@jittle-lamp/desktop",
  "version": "1.3.2",
  "description": "Jittle Lamp desktop companion, evidence reviewer, uploader, and updater.",
  "private": true,
  "type": "module",
  "main": "dist/electron/main.js",
  "scripts": {
    "dev": "JITTLE_LAMP_DESKTOP_BUILD_ENV=dev bun run build && electron .",
    "build": "bun run ./scripts/build.ts",
    "package": "bun run package:local",
    "package:local": "bun run ./scripts/package.ts --mode=local --env=stable",
    "package:ci": "bun run ./scripts/package.ts --mode=ci --env=stable",
    "package:stable": "bun run package:local",
    "package:canary": "bun run ./scripts/package.ts --mode=local --env=canary",
    "set-output": "bun run ./src/configure-output.ts",
    "typecheck": "bun x tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@clerk/clerk-react": "^5.61.3",
    "@jittle-lamp/shared": "workspace:*",
    "@jittle-lamp/viewer-core": "workspace:*",
    "@jittle-lamp/viewer-react": "workspace:*",
    "@vercel/analytics": "^2.0.1",
    "electron-updater": "6.8.3",
    "fflate": "0.8.2",
    "libsql": "0.5.29",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-router": "7.14.2"
  },
  "devDependencies": {
    "electron": "41.3.0",
    "electron-builder": "26.8.1"
  },
  "build": {
    "appId": "dev.jittlelamp.desktop",
    "productName": "Jittle Lamp",
    "directories": {
      "output": "artifacts"
    },
    "artifactName": "jittle-lamp-desktop-${version}-macos-${arch}.${ext}",
    "publish": [
      {
        "provider": "github",
        "owner": "namdien177",
        "repo": "jittle-lamp"
      }
    ],
    "files": [
      "dist/**/*",
      "package.json"
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "target": [
        "dmg",
        "zip"
      ]
    }
  }
}
