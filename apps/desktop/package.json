{
  "name": "@jittle-lamp/desktop",
  "version": "0.1.3",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun run ./src/server.ts",
    "build": "bun run ./scripts/build.ts",
    "package": "electrobun build",
    "package:stable": "electrobun build --env=stable",
    "package:canary": "electrobun build --env=canary",
    "set-output": "bun run ./src/configure-output.ts",
    "typecheck": "bun x tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@jittle-lamp/shared": "workspace:*",
    "electrobun": "^1.16.0",
    "fflate": "^0.8.2"
  }
}
