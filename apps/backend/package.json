{
  "name": "@jittle-lamp/backend",
  "version": "1.2.1",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "bun run build:js",
    "build:js": "bun build --target bun --minify-whitespace --minify-syntax --outfile dist/index.js src/index.ts",
    "build:bin": "bun build --compile --minify-whitespace --minify-syntax --target bun --outfile server src/index.ts",
    "dev": "bun --watch src/index.ts",
    "start": "bun run src/index.ts",
    "start:js": "NODE_ENV=production bun ./dist/index.js",
    "start:bin": "./server",
    "lint": "bun x @biomejs/biome check src test",
    "lint:fix": "bun x @biomejs/biome check --write src test",
    "typecheck": "bun x tsc --noEmit -p tsconfig.json",
    "test": "bun test",
    "db:generate": "bun x drizzle-kit generate --config drizzle.config.ts",
    "db:migrate": "bun x drizzle-kit migrate --config drizzle.config.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1037.0",
    "@aws-sdk/s3-request-presigner": "^3.1037.0",
    "@clerk/backend": "3.2.13",
    "@elysiajs/openapi": "latest",
    "@libsql/client": "0.17.2",
    "drizzle-orm": "0.45.2",
    "elysia": "1.4.28",
    "jose": "5.10.0",
    "pino": "9.14.0",
    "uuid": "11.1.0",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.12",
    "bun-types": "latest",
    "drizzle-kit": "0.31.10",
    "typescript": "6.0.3"
  }
}
