{
  "buildCommand": "bun run build",
  "outputDirectory": "dist",
  "installCommand": "bun install",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://jl-api.monthlyparty.com/:path*"
    },
    {
      "source": "/desktop-auth/flows",
      "destination": "https://jl-api.monthlyparty.com/desktop-auth/flows"
    },
    {
      "source": "/desktop-auth/flows/:path*",
      "destination": "https://jl-api.monthlyparty.com/desktop-auth/flows/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
